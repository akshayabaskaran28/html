<html>
<head>
    <title>Student Registration Form</title>
</head>
<body>
<center><h2><font color="darkblue">Student Registration Form</font></h2></center>
<form onsubmit="return registerStudent()">
<label>Student Name:</label><br>
<input type="text" id="name" required><br><br>
<label>Register Number:</label><br>
<input type="text" id="regno" required><br><br>
<label>Date of Birth:</label><br>
<input type="date" required><br><br>
<label>Gender:</label><br>
<input type="radio" name="gender" required> Male
<input type="radio" name="gender"> Female
<input type="radio" name="gender"> Other
<br><br>
<label>Email ID:</label><br>
<input type="email" required><br><br>
<label>Phone Number:</label><br>
<input type="tel" required><br><br>
<label>Department:</label><br>
<select required>
    <option value="">Select Department</option>
    <option>B.Sc Computer Science</option>
    <option>BCA</option>
    <option>B.Com</option>
    <option>BBA</option>
    <option>B.Sc Mathematics</option>
</select>
<br><br>
<label>Year of Study:</label><br>
<select required>
    <option value="">Select Year</option>
    <option>I Year</option>
    <option>II Year</option>
    <option>III Year</option>
</select>
<br><br>
<label>Address:</label><br>
<textarea rows="4" cols="30"></textarea><br><br>
<label>Skills:</label><br>
<input type="checkbox"> HTML
<input type="checkbox"> CSS
<input type="checkbox"> JavaScript
<input type="checkbox"> Python
<br><br>
<label>Upload Photo:</label><br>
<input type="file"><br><br>
<input type="submit" value="Register">
<input type="reset" value="Reset">
</form>
<script>
function registerStudent() {
    var name = document.getElementById("name").value;
    alert("Welcome to Student Registration!");
    var confirmRegister = confirm("Do you want to submit the registration form?");
    if (confirmRegister) {
        var message = prompt("Enter any remarks (optional):");
        alert("Registration Successful!\n\nStudent Name: " + name +
              "\nRemarks: " + message +
              "\n\nThank you for registering.");
    }
    else {
        alert("Registration Cancelled.");
    }
    return false;
}
</script>
</body>
</html>
